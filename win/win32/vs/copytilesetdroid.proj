<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="dirs.props"/>
  <Import Project="files.props"/>
  <!-- TODO not copying record-->
  <Target Name="Build">
    <Copy SkipUnchangedFiles="false" SourceFiles="$(WinWin32Dir)gnollhack_64x96_transparent_32bits.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-2.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-3.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-4.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-5.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-6.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-7.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-8.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-9.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-10.png" DestinationFolder="$(XamarinAssetsDir)"/>

    <Delete Files="$(MauiAssetsDir)gnollhack_64x96_transparent_32bits.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-2.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-3.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-4.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-5.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-6.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-7.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-8.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-9.png;$(MauiAssetsDir)gnollhack_64x96_transparent_32bits-10.png"/>

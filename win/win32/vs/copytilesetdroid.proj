    <Copy SkipUnchangedFiles="false" SourceFiles="$(WinWin32Dir)gnollhack_64x96_transparent_32bits.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-2.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-3.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-4.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-5.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-6.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-7.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-8.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-9.png;$(WinWin32Dir)gnollhack_64x96_transparent_32bits-10.png" DestinationFolder="$(MauiAssetsDir)"/>
	<Message Text="Copied tilesets from $(WinWin32Dir) to $(MauiAssetsDir)" Importance="High" />
  </Target>
  <Target Name="Clean">
